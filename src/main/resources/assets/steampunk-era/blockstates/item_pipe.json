{
  "multipart": [
    { "apply": { "model": "steampunk-era:block/item_pipe_center" } },

    { "when": { "north": "true" }, "apply": { "model": "steampunk-era:block/item_pipe_side", "x": 90 } },
    { "when": { "south": "true" }, "apply": { "model": "steampunk-era:block/item_pipe_side", "x": 270 } },
    { "when": { "east": "true" }, "apply": { "model": "steampunk-era:block/item_pipe_side", "x": 90, "y": 90 } },
    { "when": { "west": "true" }, "apply": { "model": "steampunk-era:block/item_pipe_side", "x": 90, "y": 270 } },
    { "when": { "up": "true" }, "apply": { "model": "steampunk-era:block/item_pipe_side" } },
    { "when": { "down": "true" }, "apply": { "model": "steampunk-era:block/item_pipe_side", "x": 180 } }
  ]
}